# Claude Agent SDK 配置
# 选其一即可

# 方案 A：Anthropic 官方 API
ANTHROPIC_AUTH_TOKEN=sk-ant-your_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
MODEL=claude-sonnet-4-6

# 方案 B：DeepSeek 等 Anthropic 兼容接口
# ANTHROPIC_AUTH_TOKEN=your_key_here
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# MODEL=deepseek-v4-flash

# 站点配置（部署 quartz 时使用）
SITE_BASE_URL=https://wiki.example.com
SITE_TITLE=LLM Wiki
SITE_LOCALE=zh-CN
